      - kind: EndOfLineComment
        text: "'Function GetData2(sUrl As String) As String"
      - kind: Newline
        text: "\n"
      - kind: EndOfLineComment
        text: "'Dim hOpen As Long, hFile As Long, sBuffer() As Byte, Ret As Long"
      - kind: Newline
        text: "\n"
      - kind: EndOfLineComment
        text: "'"
      - kind: Newline
        text: "\n"
      - kind: EndOfLineComment
        text: "'ReDim sBuffer(2000)"
      - kind: Newline
        text: "\n"
      - kind: EndOfLineComment
        text: "'"
      - kind: Newline
        text: "\n"
      - kind: EndOfLineComment
        text: "'hOpen = InternetOpen(\"Get Id Programme\", INTERNET_OPEN_TYPE_DIRECT, vbNullString, vbNullString, 0)"
      - kind: Newline
        text: "\n"
      - kind: EndOfLineComment
        text: "'hFile = InternetOpenUrl(hOpen, sUrl, vbNullString, ByVal 0&, INTERNET_FLAG_RELOAD Or INTERNET_FLAG_NO_CACHE_WRITE, ByVal 0&)"
      - kind: Newline
        text: "\n"
      - kind: EndOfLineComment
        text: "'InternetReadFileByte hFile, sBuffer(0), 2000, Ret"
      - kind: Newline
        text: "\n"
      - kind: EndOfLineComment
        text: "'InternetCloseHandle hFile"
      - kind: Newline
        text: "\n"
      - kind: EndOfLineComment
        text: "'InternetCloseHandle hOpen"
      - kind: Newline
        text: "\n"
      - kind: EndOfLineComment
        text: "'If Ret > 2000 Then Ret = 2000"
      - kind: Newline
        text: "\n"
      - kind: EndOfLineComment
        text: "'If Ret > 0 Then"
      - kind: Newline
        text: "\n"
      - kind: EndOfLineComment
        text: "'    ReDim Preserve sBuffer(Ret - 1)"
      - kind: Newline
        text: "\n"
      - kind: EndOfLineComment
        text: "'    GetData2 = StrConv(sBuffer, vbUnicode)"
      - kind: Newline
        text: "\n"
      - kind: EndOfLineComment
        text: "'End If"
      - kind: Newline
        text: "\n"
      - kind: EndOfLineComment
        text: "'End Function"

                    text: "'*******************************************************************************"
                  - kind: Newline
                    text: "\r\n"
                  - kind: EndOfLineComment
                    text: "'Alternative for CopyMemory - not affected by API speed issues on Windows"
                  - kind: Newline
                    text: "\r\n"
                  - kind: EndOfLineComment
                    text: "'--------------------------"
                  - kind: Newline
                    text: "\r\n"
                  - kind: EndOfLineComment
                    text: "'Mac - wrapper around CopyMemory/memmove"
                  - kind: Newline
                    text: "\r\n"
                  - kind: EndOfLineComment
                    text: "'Win - bytesCount 1 to 2147483647 - no API calls. Uses a combination of"
                  - kind: Newline
                    text: "\r\n"
                  - kind: EndOfLineComment
                    text: "'      REMOTE_MEMORY/SAFEARRAY_1D structs as well as native Strings and Arrays"
                  - kind: Newline
                    text: "\r\n"
                  - kind: EndOfLineComment
                    text: "'      to manipulate memory. Works within size limitation of Strings in VBA"
                  - kind: Newline
                    text: "\r\n"
                  - kind: EndOfLineComment
                    text: "'      For some smaller sizes (<=5) optimizes via MemLong, MemInt, MemByte etc."
                  - kind: Newline
                    text: "\r\n"
                  - kind: EndOfLineComment
                    text: "'    - bytesCount < 0 or > 2147483647 - wrapper around CopyMemory/RtlMoveMemory"
                  - kind: Newline
                    text: "\r\n"
                  - kind: EndOfLineComment
                    text: "'*******************************************************************************"
                  - kind: Newline

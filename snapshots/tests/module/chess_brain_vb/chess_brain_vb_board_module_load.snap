          - kind: FunctionKeyword
            text: Function
          - kind: Newline
            text: "\r\n"
      - kind: Newline
        text: "\r\n"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "''--- Bit functions ---"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'' many lines of codes, but very fast"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'Public Function BitsShiftLeft(ByVal Value As Long, ByVal ShiftCount As Long) As Long"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  '- Shifts the bits to the left the specified number of positions and returns the new value."
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  '- Bits \"falling off\" the left edge do not wrap around. Fill bits coming in from right are 0."
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  '- A shift left is effectively a multiplication by 2. Some common languages like C/C++ or Java have an operator for this job: \"<<\"."
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  Select Case ShiftCount"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    Case 0&"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      BitsShiftLeft = Value"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    Case 1&"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      If Value And &H40000000 Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'        BitsShiftLeft = (Value And &H3FFFFFFF) * &H2& Or &H80000000"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      Else"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'        BitsShiftLeft = (Value And &H3FFFFFFF) * &H2&"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      End If"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    Case 2&"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      If Value And &H20000000 Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'        BitsShiftLeft = (Value And &H1FFFFFFF) * &H4& Or &H80000000"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      Else"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'        BitsShiftLeft = (Value And &H1FFFFFFF) * &H4&"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      End If"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    Case 3&"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      If Value And &H10000000 Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'        BitsShiftLeft = (Value And &HFFFFFFF) * &H8& Or &H80000000"
      - kind: Newline
        text: "\r\n"

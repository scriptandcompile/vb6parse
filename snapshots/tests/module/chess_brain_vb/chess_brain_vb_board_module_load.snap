      - kind: EndOfLineComment
        text: "'Public Function WCastlingRight() As Long"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    If Moved(WKingLoc) = 0 Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      If Moved(SQ_H1) = 0 Then WCastlingRight = 1"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      If Moved(SQ_A1) = 0 Then WCastlingRight = WCastlingRight Or 2"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    Else"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      WCastlingRight = 0"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    End If"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'End Function"
      - kind: Newline
        text: "\r\n"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'Public Function BCastlingRight() As Long"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    If Moved(BKingLoc) = 0 Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      If Moved(SQ_H8) = 0 Then BCastlingRight = 1"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      If Moved(SQ_A8) = 0 Then BCastlingRight = BCastlingRight Or 2"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    Else"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      BCastlingRight = 0"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    End If"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'End Function"
      - kind: Newline
        text: "\r\n"
      - kind: Newline
        text: "\r\n"
      - kind: Newline
        text: "\r\n"

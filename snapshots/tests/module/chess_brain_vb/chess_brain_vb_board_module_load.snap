            text: "\r\n"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'Public Function SeeSign(Move As TMOVE) As Long"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  SeeSign = 0"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  ' Early return if SEE cannot be negative because captured piece value"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  ' is not less then capturing one. Note that king moves always return"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  ' here"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  If Move.Castle > 0 Or Move.Target = 0 Or Move.Piece = NO_PIECE Or Board(Move.Target) = FRAME Then Exit Function"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  If PieceType(Move.Piece) = PT_KING Then SeeSign = VALUE_KNOWN_WIN: Exit Function   ' King move always good because legal checked before"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  If Move.SeeValue = VALUE_NONE Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    If PieceAbsValue(Move.Piece) + MAX_SEE_DIFF <= PieceAbsValue(Move.Captured) Then SeeSign = VALUE_KNOWN_WIN: Exit Function ' winning or equal  move"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    ' Calculate exchange score"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    Move.SeeValue = GetSEE(Move) ' Returned for future use"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  End If"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  SeeSign = Move.SeeValue"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'End Function"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'Public Function BadSEEMove(Move As TMOVE) As Boolean"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  BadSEEMove = False"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  If Move.Castle > 0 Or Move.Target = 0 Or Move.Piece = NO_PIECE Or Board(Move.Target) = FRAME Then Exit Function"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  If PieceType(Move.Piece) = PT_KING Then Exit Function   ' King move always good because legal checked before"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  If Move.SeeValue = VALUE_NONE Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    If PieceAbsValue(Move.Piece) + MAX_SEE_DIFF <= PieceAbsValue(Move.Captured) Then Exit Function ' winning or equal  move"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    Move.SeeValue = GetSEE(Move) ' Returned for future use"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  End If"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  BadSEEMove = (Move.SeeValue < -MAX_SEE_DIFF)"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'End Function"
      - kind: Newline
        text: "\r\n"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'Public Function GoodSEEMove(Move As TMOVE) As Boolean"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  GoodSEEMove = True"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  If Move.Castle > 0 Or Move.Target = 0 Or Move.Piece = NO_PIECE Or Board(Move.Target) = FRAME Then Exit Function"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  If PieceType(Move.Piece) = PT_KING Then Exit Function   ' King move always good because legal checked before"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  If Move.SeeValue = VALUE_NONE Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    If PieceAbsValue(Move.Piece) + MAX_SEE_DIFF <= PieceAbsValue(Move.Captured) Then Exit Function ' winning or equal move"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    Move.SeeValue = GetSEE(Move) ' Returned for future use"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  End If"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  GoodSEEMove = (Move.SeeValue >= -MAX_SEE_DIFF)"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'End Function"
      - kind: Newline
        text: "\r\n"
      - kind: Newline
        text: "\r\n"

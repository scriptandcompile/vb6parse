        text: "\r\n"
      - kind: EndOfLineComment
        text: "'---------------------------------------------------------------------------"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "' AttackedCnt() - ROOK+QUEEN , BISHOP+QUEEN  added"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "' AttackedCnt attacks + DEFENDER"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'---------------------------------------------------------------------------"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'Public Function AttackedCnt(ByVal Location As Long, ByVal Color As enumColor) As Long"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  Dim i As Long, Target As Long"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  AttackedCnt = 0"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  ' Orthogonal = index 0-3"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  For i = 0 To 3"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    Target = Location + DirectionOffset(i)"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    If Color = COL_BLACK Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      If Board(Target) = BKING Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'        AttackedCnt = AttackedCnt + 1"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      Else"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'        Do While Board(Target) <> FRAME"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'          If Board(Target) = BROOK Or Board(Target) = BQUEEN Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'            AttackedCnt = AttackedCnt + 1"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'          ElseIf Board(Target) = WROOK Or Board(Target) = WQUEEN Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'            AttackedCnt = AttackedCnt - 1"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'          ElseIf Board(Target) < NO_PIECE Then ' other pieces"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'            Exit Do"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'          End If"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'          Target = Target + DirectionOffset(i)"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'        Loop"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      End If"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    Else"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      If Board(Target) = WKING Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'        AttackedCnt = AttackedCnt + 1"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      Else"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'        Do While Board(Target) <> FRAME"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'          If Board(Target) = WROOK Or Board(Target) = WQUEEN Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'            AttackedCnt = AttackedCnt + 1"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'          ElseIf Board(Target) = BROOK Or Board(Target) = BQUEEN Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'            AttackedCnt = AttackedCnt - 1"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'          ElseIf Board(Target) < NO_PIECE Then ' other pieces"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'            Exit Do"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'          End If"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'          Target = Target + DirectionOffset(i)"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'        Loop"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      End If"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    End If"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  Next"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  ' Diagonal = index 4 to 7"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  For i = 4 To 7"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    Target = Location + DirectionOffset(i)"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    If Color = COL_BLACK Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      If Board(Target) = BKING Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'        AttackedCnt = AttackedCnt + 1"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      Else"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'        If Board(Target) = BPAWN And ((i = 4) Or (i = 6)) Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'          AttackedCnt = AttackedCnt + 1"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'          Target = Location + DirectionOffset(i)"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'        End If"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'        Do While Board(Target) <> FRAME"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'          If Board(Target) = BBISHOP Or Board(Target) = BQUEEN Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'            AttackedCnt = AttackedCnt + 1"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'          ElseIf Board(Target) = WBISHOP Or Board(Target) = WQUEEN Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'            AttackedCnt = AttackedCnt - 1"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'          ElseIf Board(Target) < NO_PIECE Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'            Exit Do"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'          End If"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'          Target = Target + DirectionOffset(i)"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'        Loop"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      End If"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    Else"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      If Board(Target) = WKING Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'        AttackedCnt = AttackedCnt + 1"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      Else"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'        If Board(Target) = WPAWN And ((i = 5) Or (i = 7)) Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'          AttackedCnt = AttackedCnt + 1"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'          Target = Location + DirectionOffset(i)"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'        End If"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'        Do While Board(Target) <> FRAME"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'          If Board(Target) = WBISHOP Or Board(Target) = WQUEEN Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'            AttackedCnt = AttackedCnt + 1"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'          ElseIf Board(Target) = BBISHOP Or Board(Target) = BQUEEN Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'            AttackedCnt = AttackedCnt - 1"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'          ElseIf Board(Target) < NO_PIECE Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'            Exit Do"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'          End If"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'          Target = Target + DirectionOffset(i)"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'        Loop"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      End If"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    End If"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  Next"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  ' Knight moves"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  For i = 0 To 7"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    Target = Location + KnightOffsets(i)"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    If Color = COL_BLACK Then"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      If Board(Target) = BKNIGHT Then AttackedCnt = AttackedCnt + 1"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      If Board(Target) = WKNIGHT Then AttackedCnt = AttackedCnt - 1"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    Else"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      If Board(Target) = WKNIGHT Then AttackedCnt = AttackedCnt + 1"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      If Board(Target) = BKNIGHT Then AttackedCnt = AttackedCnt - 1"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    End If"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  Next"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'End Function"
      - kind: Newline
        text: "\r\n"
      - kind: Newline
        text: "\r\n"

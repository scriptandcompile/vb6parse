        text: "'Public Function Alpha2Piece(ByVal sPiece As String, ByVal bWhiteToMove As Boolean) As Long"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  Dim a As Long"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  Select Case LCase(sPiece)"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    Case \"n\""
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      a = WKNIGHT"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    Case \"b\""
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      a = WBISHOP"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    Case \"r\""
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      a = WROOK"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'    Case \"q\""
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'      a = WQUEEN"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  End Select"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  If a > 0 And Not bWhiteToMove Then a = a + 1"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'  Alpha2Piece = a"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'End Function"
      - kind: Newline
        text: "\r\n"

                                                          - kind: IfStatement
                                                            children:
                                                              - kind: Whitespace
                                                                text: " "
                                                              - kind: IfKeyword
                                                                text: If
                                                              - kind: IdentifierExpression
                                                                children:
                                                                  - kind: Newline
                                                                    text: "\r\n"
                                                              - kind: EndKeyword
                                                                text: End
                                                              - kind: Whitespace
                                                                text: " "
                                                              - kind: SubKeyword
                                                                text: Sub
                                                              - kind: Newline
                                                                text: "\r\n"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'Public Sub SendRootInfo(Elapsed As Single, ActDepth As Long, CurrentScore As Long, Alpha As Long, Beta As Long)"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  Dim sPost As String, j As Long, sPV As String"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  'CurrentScore = ScaleScoreByEGTB(CurrentScore)"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  If pbIsOfficeMode Then"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'    '--- MS OFFICE"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'    sPost = \" \" & Translate(\"Depth\") & \":\" & ActDepth & \"/\" & MaxPly & \" \" & Translate(\"Score\") & \":\" & FormatScore(EvalSFTo100(CurrentScore)) & \" \" & Translate(\"Nodes\") & \":\" & Format(\"0.000\", CalcNodes()) & \" \" & Translate(\"Sec\") & \":\" & Format(Elapsed, \"0.00\")"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'    If plLastPostNodes <> Nodes Or Nodes = 0 Then"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'      SendCommand sPost"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'      plLastPostNodes = Nodes"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'      sPost = \"      >Line: \""
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'      For j = 1 To PVLength(1) - 1"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'        sPost = sPost & \" \" & MoveText(PV(1, j))"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'      Next"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'      SendCommand sPost"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'      ShowMoveInfo MoveText(FinalMove), ActDepth, MaxPly, EvalSFTo100(CurrentScore), Elapsed"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'    End If"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  Else"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'    ' VB6"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'    If UCIMode Then"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'      ' format: info depth 1 seldepth 1 multipv 1 score cp 417 nodes 51 nps 25500 tbhits 0 time 2 pv e8g8"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'      sPost = \"info depth \" & ActDepth & \" seldepth \" & MaxPly & \" multipv 1 score \" & UciGUIScore(CurrentScore, Alpha, Beta) & \" nodes \" & CalcNodes() & \" nps \" & CalcNPS(Elapsed) & \" tbhits \" & EGTBasesHitsCnt & \" time \" & Int(Elapsed * 1000#) & \" pv\""
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'    Else"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'      sPost = ActDepth & \" \" & EvalSFTo100(CurrentScore) & \" \" & (Int(Elapsed) * 100) & \" \" & CalcNodes()"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'    End If"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'    sPV = \"\""
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'    For j = 1 To PVLength(1) - 1"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'      If PV(1, j).From <> 0 Then sPV = sPV & \" \" & GUIMoveText(PV(1, j))"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'    Next"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'    If Len(Trim(sPV)) > 8 Then"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'      LastFullPV = sPV"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'    Else"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'      If Trim(Left(sPV, 5)) = Trim(Left(LastFullPV, 5)) Then"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'        sPV = LastFullPV"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'      End If"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'    End If"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'    sPost = sPost & sPV"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'    If Not GotExitCommand() Then"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'      SendCommand sPost"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'    End If"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  End If"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  If bWinboardTrace Then If bLogPV Then LogWrite Space(6) & sPost"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'End Sub"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: DimStatement
                                                            children:
                                                              - kind: PublicKeyword
                                                                text: Public
                                                              - kind: Whitespace
                                                                text: " "
                                                              - kind: FunctionKeyword
                                                                text: Function
                                                              - kind: Whitespace
                                                                text: " "
                                                              - kind: Identifier
                                                                text: GotExitCommand
                                                              - kind: LeftParenthesis
                                                                text: (
                                                              - kind: RightParenthesis
                                                                text: )
                                                              - kind: Whitespace
                                                                text: " "
                                                              - kind: AsKeyword
                                                                text: As
                                                              - kind: Whitespace
                                                                text: " "

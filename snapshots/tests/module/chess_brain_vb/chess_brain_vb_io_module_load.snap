                                                                                    text: "\r\n"
                                                                                  - kind: Whitespace
                                                                                    text: "  "
                                                                                  - kind: EndOfLineComment
                                                                                    text: "'    ' keep 0"
                                                                                  - kind: Newline
                                                                                    text: "\r\n"
                                                                                  - kind: Whitespace
                                                                                    text: "  "
                                                                                  - kind: EndOfLineComment
                                                                                    text: "'  End Select"

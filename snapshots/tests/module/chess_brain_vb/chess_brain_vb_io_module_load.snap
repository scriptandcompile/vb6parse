                                                                                    text: "'  sResult = \"\"\"checkmate\"\":false,\"\"stalemate\"\":false,\"\"variant_win\"\":false,\"\"variant_loss\"\":false,\"\"insufficient_material\"\":false,\"\"dtz\"\":-4,\"\"precise_dtz\"\":-4,\"\"dtm\"\":-10,\"\"category\"\":\"\"loss\"\",\"\"moves\"\":[{\"\"uci\"\":\"\"g7h8\"\",\"\"san\"\":\"\"Kh8\"\",\"\"zeroing\"\":false,\"\"checkmate\"\":false,\"\"stalemate\"\":false,\"\"variant_win\"\":false,\"\"variant_loss\"\":false,\"\"insufficient_material\"\":false,\"\"dtz\"\":3,\"\"precise_dtz\"\":3,\"\"dtm\"\":9,\"\"category\"\":\"\"win\"\"}\""

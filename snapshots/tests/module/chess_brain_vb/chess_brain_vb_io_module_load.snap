                                                          - kind: Unknown
                                                            text: Function
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: Whitespace
                                                            text: "  "
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'Public Function ProbeOnlineEGTB(ByVal sFEN As String, _"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'                                ByRef GameResultScore As Long, _"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'                                ByVal bShowBestMoves As Boolean, _"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'                                ByRef BestMove As String, _"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'                                ByRef BestMovesList As String) As Boolean"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  ' Online Web Access needed !"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  ' Documentation: http://www.lokasoft.nl/tbapi.aspx"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  ' Comsvcs.dll needed"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  ' function returns false if no result"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  Static bInitDone As Boolean"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  Static bInitOk   As Boolean"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  Dim sResult      As String, sCommand As String"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  GameResultScore = VALUE_NONE: BestMove = \"\": BestMovesList = \"\": ProbeOnlineEGTB = False"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  If Not bInitDone Then"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'    bInitOk = InitTableBases()"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'    bInitDone = True"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  End If"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  If Not bInitOk Then ProbeOnlineEGTB = False: Exit Function"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  On Error GoTo lblErr"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  ' The score is given as distance to mat, or 0 when the position is a draw."
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  ' An error response is returned when position is invalid or not in database. '"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  ' e.g.  M5 = color to move gives mate in 5 , -M3 = color to move gets mated in 5 moves."
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  sCommand = \"curl http://tablebase.lichess.ovh/standard/mainline?fen=4k3/8/8/8/8/4K3/8/8_w_-_\""
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  sResult = GetCommandOutput(sCommand)"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  If Trim$(sResult) = \"\" Then Exit Function  ' TODO Trim$(oProxy.ProbePosition(sFEN))"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  If sResult = \"0\" Then"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'    GameResultScore = 0"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  ElseIf Left$(sResult, 1) = \"M\" Then"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'    GameResultScore = MATE0 - 2 * Val(\"0\" & Mid$(sResult, 2))"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  ElseIf Left$(sResult, 2) = \"-M\" Then"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'    GameResultScore = -MATE0 + 2 * Val(\"0\" & Mid$(sResult, 3))"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  End If"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  ' Shows list of best move"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  If GameResultScore <> VALUE_NONE Then"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'    ProbeOnlineEGTB = True"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'    If bShowBestMoves Then"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'      BestMovesList = \"\" ' TODO"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'    End If"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  End If"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  If bEGTbBaseTrace Then WriteTrace \"endgame tablebase move: \" & BestMove & \" / Score: \" & GameResultScore & \" \" & Now() & vbCrLf & PrintPos()"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'lblExit:"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  Exit Function"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'lblErr:"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  bInitDone = False"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  ProbeOnlineEGTB = False"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'  Resume lblExit"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: EndOfLineComment
                                                            text: "'End Function"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: Newline
                                                            text: "\r\n"
                                                          - kind: DimStatement

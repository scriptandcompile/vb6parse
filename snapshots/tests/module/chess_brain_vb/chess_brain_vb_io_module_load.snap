                                                                                    text: "'If MoveCnt > 0 Then"
                                                                                  - kind: Newline
                                                                                    text: "\r\n"
                                                                                  - kind: Whitespace
                                                                                    text: "  "
                                                                                  - kind: EndOfLineComment
                                                                                    text: "'  Select Case sResult"
                                                                                  - kind: Newline
                                                                                    text: "\r\n"
                                                                                  - kind: Whitespace
                                                                                    text: "  "
                                                                                  - kind: EndOfLineComment
                                                                                    text: "'  Case \"Win\""
                                                                                  - kind: Newline
                                                                                    text: "\r\n"
                                                                                  - kind: Whitespace
                                                                                    text: "  "
                                                                                  - kind: EndOfLineComment
                                                                                    text: "'    If BestCaptureVal > 150 Then MoveCnt = MoveCnt \\ 2"
                                                                                  - kind: Newline
                                                                                    text: "\r\n"
                                                                                  - kind: Whitespace
                                                                                    text: "  "
                                                                                  - kind: EndOfLineComment
                                                                                    text: "'    GameResultScore = ScorePawn.EG * 20# - 3 * MoveCnt"
                                                                                  - kind: Newline
                                                                                    text: "\r\n"
                                                                                  - kind: Whitespace
                                                                                    text: "  "
                                                                                  - kind: EndOfLineComment
                                                                                    text: "'  Case \"Loss\""
                                                                                  - kind: Newline
                                                                                    text: "\r\n"
                                                                                  - kind: Whitespace
                                                                                    text: "  "
                                                                                  - kind: EndOfLineComment
                                                                                    text: "'    If BestCaptureVal > 150 Then MoveCnt = MoveCnt + 200 ' prefer good captures"
                                                                                  - kind: Newline
                                                                                    text: "\r\n"
                                                                                  - kind: Whitespace
                                                                                    text: "  "
                                                                                  - kind: EndOfLineComment
                                                                                    text: "'    GameResultScore = -(ScorePawn.EG * 20# - 6 * MoveCnt)"
                                                                                  - kind: Newline
                                                                                    text: "\r\n"
                                                                                  - kind: Whitespace
                                                                                    text: "  "
                                                                                  - kind: EndOfLineComment
                                                                                    text: "'  Case Else"

                                                                                          - kind: EndOfLineComment
                                                                                            text: "'If Fifty >= 4 Then ' fifty move draw: make different hash when fifty increases every 8 moves > prolbem with 3x draw detection using hash"
                                                                                          - kind: Newline
                                                                                            text: "\r\n"
                                                                                          - kind: Whitespace
                                                                                            text: "  "
                                                                                          - kind: EndOfLineComment
                                                                                            text: "'  FiftyHash.HashKey1 = Hashkey.HashKey1 Xor FiftyZobristTable(Fifty \\ 8): FiftyHash.Hashkey2 = Hashkey.Hashkey2 Xor FiftyZobristTable2(Fifty \\ 8)"
                                                                                          - kind: Newline

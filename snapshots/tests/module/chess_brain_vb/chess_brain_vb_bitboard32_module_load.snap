                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'  m1 = EmptyMove"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: " "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'  m2 = m3"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: " "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'  m3 = m1"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "   "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'1. ---"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "  "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'x = 23 + i Mod 2"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "   "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'SetBit64 b, x"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "  "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'If x < 32& Then If x = 31 Then b.i0 = b.i0 Or BitL_31 Else b.i0 = b.i0 Or Bit32Pos(x) Else If x = 63 Then b.i1 = b.i1 Or BitL_31 Else b.i1 = b.i1 Or Bit32Pos(x - 32)"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "  "
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "  "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'x = x + 20"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "  "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'SetBit64 b, x"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "  "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'If x < 32& Then If x = 31 Then b.i0 = b.i0 Or BitL_31 Else b.i0 = b.i0 Or Bit32Pos(x) Else If x = 63 Then b.i1 = b.i1 Or BitL_31 Else b.i1 = b.i1 Or Bit32Pos(x - 32)"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "  "
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "  "
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "  "
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "  "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'For j = 1 To 7"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "  "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'  bb.i0 = AttackedByBB(1, j).i0: bb.i1 = AttackedByBB(1, j).i1"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "  "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'  b.i0 = bb.i0: b.i1 = bb.i1"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "    "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'b.i0 = bb.i0 Or t.i0: b.i1 = bb.i1 Or t.i1"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "    "
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "    "
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "    "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'bb = AttackedByBB(1, j)"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "    "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'Set64 b, bb"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "    "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'b = bb"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "    "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'OR64 b, bb, t"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "  "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'Next"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "  "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'------------------------------------------------"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "   "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'z = 31 + i Mod 2"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "  "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'2.---"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "  "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'AttackedByBB(1, PT_PAWN).i0 = AttackedByBB(1, PT_PAWN).i0 Or SquareBB(z).i0: AttackedByBB(1, PT_PAWN).i1 = AttackedByBB(1, PT_PAWN).i1 Or SquareBB(z).i1"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "  "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'SetOR64 AttackedByBB(1, PT_PAWN), SquareBB(z)"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "  "
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "  "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'3.---"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "  "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'bb.i0 = b.i0 Or SquareBB(z).i0: bb.i1 = b.i1 Or SquareBB(z).i1"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "  "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "' bb = Or64(b, SquareBB(z)) ' 24,6"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "  "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'Or64To b, SquareBB(z), bb ' 3,7"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "  "
                                                                                                              - kind: EndOfLineComment
                                                                                                                text: "'Or64ToP b, SquareBB(z)    ' 2,6"
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"
                                                                                                              - kind: Whitespace
                                                                                                                text: "  "
                                                                                                              - kind: Newline
                                                                                                                text: "\r\n"

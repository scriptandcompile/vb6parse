      - kind: EndOfLineComment
        text: "'    // Get enumerator for audio endpoint devices."
      - kind: Newline
        text: "\n"
      - kind: EndOfLineComment
        text: "'    hr = CoCreateInstance(__uuidof(MMDeviceEnumerator),"
      - kind: Newline
        text: "\n"
      - kind: EndOfLineComment
        text: "'                          NULL, CLSCTX_INPROC_SERVER,"
      - kind: Newline
        text: "\n"
      - kind: EndOfLineComment
        text: "'                          __uuidof(IMMDeviceEnumerator),"
      - kind: Newline
        text: "\n"
      - kind: EndOfLineComment
        text: "'                          (void**)&pEnumerator);"
      - kind: Newline
        text: "\n"
      - kind: Newline
        text: "\n"
      - kind: Newline
        text: "\n"
      - kind: EndOfLineComment
        text: "'    // Get peak meter for default audio-rendering device."
      - kind: Newline
        text: "\n"
      - kind: EndOfLineComment
        text: "'    hr = pEnumerator->GetDefaultAudioEndpoint(eRender, eConsole, &pDevice);"
      - kind: Newline
        text: "\n"
      - kind: Newline
        text: "\n"
      - kind: Newline
        text: "\n"
      - kind: EndOfLineComment
        text: "'    hr = pDevice->Activate(__uuidof(IAudioMeterInformation),"
      - kind: Newline
        text: "\n"
      - kind: EndOfLineComment
        text: "'                           CLSCTX_ALL, NULL, (void**)&pMeterInfo);"
      - kind: Newline
        text: "\n"
      - kind: Newline
        text: "\n"
      - kind: Newline
        text: "\n"

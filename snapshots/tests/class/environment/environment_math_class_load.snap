      - kind: Newline
        text: "\r\n"
      - kind: FunctionStatement
        children:
          - kind: PrivateKeyword
            text: Private
          - kind: Whitespace
            text: " "
          - kind: FunctionKeyword
            text: Function
          - kind: Whitespace
            text: " "
          - kind: Identifier
            text: SegFromLines
          - kind: ParameterList
            children:
              - kind: LeftParenthesis
                text: (
              - kind: Identifier
                text: Origin
              - kind: Whitespace
                text: " "
              - kind: AsKeyword
                text: As
              - kind: Whitespace
                text: " "
              - kind: Identifier
                text: VecType
              - kind: Comma
                text: ","
              - kind: Whitespace
                text: " "
              - kind: Identifier
                text: Line1
              - kind: Whitespace
                text: " "
              - kind: AsKeyword
                text: As
              - kind: Whitespace
                text: " "
              - kind: Identifier
                text: LineType
              - kind: Comma
                text: ","
              - kind: Whitespace
                text: " "
              - kind: Identifier
                text: Line2
              - kind: Whitespace
                text: " "
              - kind: AsKeyword
                text: As
              - kind: Whitespace
                text: " "
              - kind: Identifier
                text: LineType
              - kind: Comma
                text: ","
              - kind: Whitespace
                text: " "
              - kind: OptionalKeyword
                text: Optional
              - kind: Whitespace
                text: " "
              - kind: Identifier
                text: Order
              - kind: Whitespace
                text: " "
              - kind: AsKeyword
                text: As
              - kind: Whitespace
                text: " "
              - kind: DoubleKeyword
                text: Double
              - kind: Whitespace
                text: " "
              - kind: EqualityOperator
                text: "="
              - kind: Whitespace
                text: " "
              - kind: IdentifierExpression
                children:
                  - kind: Identifier
                    text: xyz
              - kind: RightParenthesis
                text: )
          - kind: Whitespace
            text: " "
          - kind: AsKeyword
            text: As
          - kind: Whitespace
            text: " "
          - kind: Identifier
            text: SegType
          - kind: Newline
            text: "\r\n"
          - kind: StatementList
            children:
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "' This returns an ordered basis (following the right-hand-rule) with all vectors being a unit-in-length (orthonormal)."
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "' This function is designed to replicate the line in BodyBuilder that allows you to create a segment from an origin and two lines (but just for one frame):"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'       Segment = [Origin, Line1.Point1 - Line1.Point2, Line2.Point1 - Line2.Point2, Order]"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "' Note that the output axes are set at origin <0,0,0>.  Only the origin reflects an offset translation."
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "' The return axes will always be orthonormal."
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'                                                                        (Up)"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'                                                                          Z"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "' The figure at right attempts to illustrate one of these segments:        |    Y (Left, North)"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "' This is the output of this function.                                     |   /"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'                                                                          |  /"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'                                                                          | /"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'                                                                          |/"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'                                                                 (Origin) *------- X (Forward, East)"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "' The input is an origin and two lines.  The origin really stands alone and often isn't terribly important,"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "' especially if we're just concerned with rotations."
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "' The actual axes of the segment are constructed from the two lines, and things are constructed differently depending on the specified order."
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "' The first line (Line1) defines the first letter of the order of the segment, with the positive direction defined by Line1.Point1"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "' (and the line's origin defined by Line1.Point2).  The following may help:"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'       For Xyz(1) & Xzy(-1)    AxisX is defined by Line1 with positive heading to Line1.Point1."
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'       For Yzx(2) & Yxz(-2)    AxisY is defined by Line1 with positive heading to Line1.Point1."
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'       For Zxy(3) & Zyx(-3)    AxisZ is defined by Line1 with positive heading to Line1.Point1."
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "' The second line (Line2) approximates the last (third) letter of the order, with the alphabetic order specifying whether Line2.Point1 or Line2.Point2 is positive."
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "' With respect to Line2, the following may provide as a cheat-sheet:"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'       For xyZ(1)      AxisZ is approximated by Line2 with positive heading to Line2.Point1."
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'       For xzY(-1)     AxisY is approximated by Line2 with positive heading to Line2.Point2."
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'       For yzX(2)      AxisX is approximated by Line2 with positive heading to Line2.Point1."
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'       For yxZ(-2)     AxisZ is approximated by Line2 with positive heading to Line2.Point2."
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'       For zxY(3)      AxisY is approximated by Line2 with positive heading to Line2.Point1."
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'       For zyX(-3)     AxisX is approximated by Line2 with positive heading to Line2.Point2."
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "' Now, we've still got another axis of our segment to address.  For instance, for XYZ, we've yet to talk about Y."
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "' This \"middle\" axis is defined by the cross product of the other two axes."
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "' Also when discussing the last axis, I used the word \"approximate\".  I did this because, once the middle axis is determined,"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "' this \"last\" axis is recalculated as the cross product of the first two.  This is the way an orthogonal segment is achieved."
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "' The following are the actual calculations (with × denoting a cross product):"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'       LineA = (Line1.Point1 - Line1.Point2)          ; Unitized."
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'       LineB = (Line2.Point1 - Line2.Point2)          ; Unitized."
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'       If constant is XYZ (1):         AxisX = LineA"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'                                       AxisY = LineB × LineA"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'                                       AxisZ = LineA × AxisY"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'       If constant is XZY (-1):        AxisX = LineA"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'                                       AxisZ = LineB × LineA"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'                                       AxisY = AxisZ × LineA"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'       If constant is YZX (2):         AxisY = LineA"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'                                       AxisZ = LineB × LineA"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'                                       AxisX = LineA × AxisZ"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'       If constant is YXZ (-2):        AxisY = LineA"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'                                       AxisX = LineB × LineA"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'                                       AxisZ = AxisX × LineA"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'       If constant is ZXY (3):         AxisZ = LineA"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'                                       AxisX = LineB × LineA"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'                                       AxisY = LineA × AxisX"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'       If constant is ZYX (-3):        AxisZ = LineA"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'                                       AxisY = LineB × LineA"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'                                       AxisX = AxisY × LineA"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "' And finally, here's another cheat-sheet that may help:"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'       Segment = [Point0, (L1.p1 - L1.p2), (L2.p1 - L2.p2), xyz]       (1)"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'                  Origin     + AxisX -        + AxisZ -"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "    "
              - kind: EndOfLineComment
                text: "'"

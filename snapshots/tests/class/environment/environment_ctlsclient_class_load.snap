                                                                              - kind: Whitespace
                                                                                text: " "
                                                                              - kind: IdentifierExpression
                                                                                children:
                                                                                  - kind: Identifier
                                                                                    text: ISC_REQ_EXTENDED_ERROR
                                                                      - kind: Whitespace
                                                                        text: "             "
                                                                      - kind: EndOfLineComment
                                                                        text: "' When errors occur, the remote party will be notified."
                                                                      - kind: Newline
                                                                        text: "\r\n"
                                                                      - kind: Whitespace
                                                                        text: "    "
                                                                      - kind: AssignmentStatement
                                                                        children:
                                                                          - kind: IdentifierExpression
                                                                            children:
                                                                              - kind: Identifier
                                                                                text: lContextReq
                                                                          - kind: Whitespace
                                                                            text: " "

                                                                          - kind: BinaryExpression
                                                                            children:
                                                                              - kind: IdentifierExpression
                                                                                children:
                                                                                  - kind: Identifier
                                                                                    text: lContextReq
                                                                              - kind: Whitespace
                                                                                text: " "

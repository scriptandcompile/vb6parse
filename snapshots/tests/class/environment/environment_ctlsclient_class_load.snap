                                                                                children:
                                                                                  - kind: Identifier
                                                                                    text: ISC_REQ_STREAM
                                                                      - kind: Whitespace
                                                                        text: "                     "
                                                                      - kind: EndOfLineComment
                                                                        text: "' Support a stream-oriented connection."
                                                                      - kind: Newline
                                                                        text: "\r\n"
                                                                      - kind: EndOfLineComment
                                                                        text: "'    lContextReq = lContextReq Or ISC_REQ_INTEGRITY                 ' Sign messages and verify signatures by using the EncryptMessage and MakeSignature functions."
                                                                      - kind: Newline
                                                                        text: "\r\n"
                                                                      - kind: EndOfLineComment

                                                                                text: Or
                                                                              - kind: Whitespace
                                                                                text: " "
                                                                              - kind: IdentifierExpression
                                                                                children:
                                                                                  - kind: Identifier
                                                                                    text: ISC_REQ_CONFIDENTIALITY
                                                                      - kind: Whitespace
                                                                        text: "            "
                                                                      - kind: EndOfLineComment
                                                                        text: "' Encrypt messages by using the EncryptMessage function."
                                                                      - kind: Newline
                                                                        text: "\r\n"
                                                                      - kind: EndOfLineComment
                                                                        text: "'    lContextReq = lContextReq Or ISC_REQ_USE_SUPPLIED_CREDS         ' Schannel must not attempt to supply credentials for the client automatically."
                                                                      - kind: Newline
                                                                        text: "\r\n"
                                                                      - kind: Whitespace
                                                                        text: "    "
                                                                      - kind: AssignmentStatement
                                                                        children:
                                                                          - kind: IdentifierExpression
                                                                            children:
                                                                              - kind: Identifier
                                                                                text: lContextReq
                                                                          - kind: Whitespace
                                                                            text: " "
                                                                          - kind: EqualityOperator
                                                                            text: "="
                                                                          - kind: Whitespace

                                                      - kind: Whitespace
                                                        text: " "
                                                      - kind: Identifier
                                                        text: Trm_CD_Animation_Timer
                                                      - kind: LeftParenthesis
                                                        text: (
                                                      - kind: RightParenthesis
                                                        text: )
                                                      - kind: Newline
                                                        text: "\n"
                                                  - kind: EndOfLineComment
                                                    text: "'Dim ImgIndex As Integer"
                                                  - kind: Newline
                                                    text: "\n"
                                                  - kind: EndOfLineComment
                                                    text: "'"
                                                  - kind: Newline
                                                    text: "\n"
                                                  - kind: EndOfLineComment
                                                    text: "'ImgIndex = Trm_CD_Animation.Tag"
                                                  - kind: Newline
                                                    text: "\n"
                                                  - kind: EndOfLineComment
                                                    text: "'"
                                                  - kind: Newline
                                                    text: "\n"
                                                  - kind: EndOfLineComment
                                                    text: "'AniCD.Picture = ImageList5.ListImages(ImgIndex).Picture"
                                                  - kind: Newline
                                                    text: "\n"
                                                  - kind: EndOfLineComment
                                                    text: "'AniCD.Visible = True"
                                                  - kind: Newline
                                                    text: "\n"
                                                  - kind: EndOfLineComment
                                                    text: "'"
                                                  - kind: Newline
                                                    text: "\n"
                                                  - kind: EndOfLineComment
                                                    text: "'If DoorClose = True Then"
                                                  - kind: Newline
                                                    text: "\n"
                                                  - kind: EndOfLineComment
                                                    text: "'    If Trm_CD_Animation.Tag = 1 Then"
                                                  - kind: Newline
                                                    text: "\n"
                                                  - kind: EndOfLineComment
                                                    text: "'        DoorClose = False"
                                                  - kind: Newline
                                                    text: "\n"
                                                  - kind: EndOfLineComment
                                                    text: "'        Trm_CD_Animation.Enabled = False"
                                                  - kind: Newline
                                                    text: "\n"
                                                  - kind: EndOfLineComment
                                                    text: "'        AniCD.Visible = False"
                                                  - kind: Newline
                                                    text: "\n"
                                                  - kind: EndOfLineComment
                                                    text: "'    Else"
                                                  - kind: Newline
                                                    text: "\n"
                                                  - kind: EndOfLineComment
                                                    text: "'        Trm_CD_Animation.Tag = Trm_CD_Animation.Tag - 1"
                                                  - kind: Newline
                                                    text: "\n"
                                                  - kind: EndOfLineComment
                                                    text: "'    End If"
                                                  - kind: Newline
                                                    text: "\n"
                                                  - kind: EndOfLineComment
                                                    text: "'Else"
                                                  - kind: Newline
                                                    text: "\n"
                                                  - kind: EndOfLineComment
                                                    text: "'    If Trm_CD_Animation.Tag = 7 Then"
                                                  - kind: Newline
                                                    text: "\n"
                                                  - kind: EndOfLineComment
                                                    text: "'        DoorClose = True"
                                                  - kind: Newline
                                                    text: "\n"
                                                  - kind: EndOfLineComment
                                                    text: "'        Trm_CD_Animation.Enabled = False"
                                                  - kind: Newline
                                                    text: "\n"
                                                  - kind: EndOfLineComment
                                                    text: "'    Else"
                                                  - kind: Newline
                                                    text: "\n"
                                                  - kind: EndOfLineComment
                                                    text: "'        Trm_CD_Animation.Tag = Trm_CD_Animation.Tag + 1"
                                                  - kind: Newline
                                                    text: "\n"
                                                  - kind: EndOfLineComment
                                                    text: "'    End If"
                                                  - kind: Newline
                                                    text: "\n"
                                                  - kind: EndOfLineComment
                                                    text: "'End If"
                                                  - kind: Newline
                                                    text: "\n"
                                                  - kind: Unknown
                                                    text: End
                                                  - kind: Whitespace
                                                    text: " "
                                                  - kind: Unknown
                                                    text: Sub
                                                  - kind: Newline
                                                    text: "\n"

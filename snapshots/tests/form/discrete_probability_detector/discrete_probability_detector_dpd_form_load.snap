cst:
  root:
    kind: Root
    children:
      - kind: EndOfLineComment
        text: "'###################################################################################################"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# John Wiley & Sons, Inc.                                                                         #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#                                                                                                 #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# Book:   Markov Chains: From Theory To Implementation And Experimentation                        #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# Author: Dr. Paul Gagniuc                                                                        #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# Data:   01/05/2017                                                                              #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#                                                                                                 #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# Title:                                                                                          #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# Discrete Probability Detector                                                                   #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#                                                                                                 #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# Short Description:                                                                              #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# The purpose of this algorithm is to convert any string into a probability matrix.               #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#_______________________                                                                          #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# Detailed description: \\                                                                         #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# This algorithm is an advanced variation of the \"ExtractProb\" function from the book. The        #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# main difference between \"ExtractProb\" function and the DPD algorithm is the automatic           #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# identification of states.                                                                       #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#_________________________________________________________________________________________________#"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# Initially, the states are identified in the first phase. Each new letter found in \"S\" is        #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# appended to the string forming in variable \"a\". Thus, variable \"a\" gradually increases until    #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# all types of letters from \"S\" are identified.                                                   #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#_________________________________________________________________________________________________#"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# In the second phase the elements of matrix \"m\" are filled with zero values for later            #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# purposes. Also, in the second phase the first column of matrix \"e\" is filled with letters       #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# found in variable \"a\", and the second column of matrix \"e\" is filled with zero values for       #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# later use.                                                                                      #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#_________________________________________________________________________________________________#"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# In the third phase, the transitions between letters of \"S\" are counted and stored in            #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# matrix \"m\".                                                                                     #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# The strategy in this particular case is to fill matrix \"m\" with transition counts before the    #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# last letter in \"S\" is reached. In this case, the first column of matrix \"e\" already contains    #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# the letters from variable \"a\". The two components of vector \"l\" contain the \"i\" and \"i+1\"       #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# letters from \"S\". The count of individual transitions between letters is made by a comparison   #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# between vector \"l\" and the elements from the first column of matrix \"e\". The number of rows     #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# in matrix \"m\" and matrix \"e\" is the same, namely \"d\". Therefore, an extra loop can be avoided   #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# by mapping matrix \"m\" through a coordinate system. For instance, if the letter from position    #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# \"i\" in \"S\" stored in \"l(0)\" and the letter from \"j\" row in matrix \"e\" (e(j,0)) are the same     #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# then variable \"r = j\". Likewise, if the letter \"i+1\" stored in l(1) and the letter from e(j,0)  #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# are the same then variable \"c = j\". Variable \"r\" represents the rows of matrix \"m\", whereas     #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# variable \"c\" represents the columns of matrix \"m\" (m(r, c)).                                    #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# Thus, at each step through \"S\", an element of matrix \"m\" is always incremented according to     #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# the coordinates received from \"r\" and \"c\". This \"coordinate\" approach greatly increases the     #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# processing speed of the algorithm. The number of loops = (k-1)*d, where \"d\" represents the      #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# number of states (or letter types), and \"k\" is the number of letters in \"S\". When the letter    #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# stored in \"l(0)\" and the letter from \"j\" row in matrix \"e\" are the same, the second column of   #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# matrix \"e\" is also incremented. The second column of matrix \"e\" stores the number of            #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# appearances for each type of letter in \"S\".                                                     #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#_________________________________________________________________________________________________#"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# In the fourth phase, the counts from matrix \"m\" elements are divided by the counts from the     #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# second column of matrix \"e\". The result of this division is stored in the same position in      #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# matrix \"m\", and represents a transition probability.                                            #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#_________________________________________________________________________________________________#"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#                                                                                                 #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# Special considerations:                                                                         #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#                                                                                                 #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# If a state at the end of \"S\" (ie HAHAAAHQ) does not occur in the rest of \"S\" then matrix \"m\"    #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# will contain a row with all elements on zero. Since it is at the end of \"S\", the letter does    #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# not make a transition to anything. If a state from the beginning of \"S\" (ie. QHAHAAAH) does     #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# not occur in the rest of \"S\" then matrix \"m\" will contain a column with all elements on zero.   #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# Since the first letter it is only seen at the beginning of \"S\", no other letter makes a         #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# transition to it.                                                                               #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#                                                                                                 #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# The meaning of variables:                                                                       #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#      _____________________________________________________________________________________      #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# S = |The string that is being analyzed.                                                  _|     #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#      _____________________________________________________________________________________      #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# q = |It is a flag variable with initial value of 1. The value of q becomes zero only if a |     #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#     |letter x in the \"S\" string coresponds with a letter y in the \"a\" string.            _|     #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#      _____________________________________________________________________________________      #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# a = |The variable that holds the letters representing the states. The variable gradually  |     #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#     |increases in length as the \"S\" string is analyzed. At each loop, a new letter is     |     #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#     |added to variable \"a\" only if the value of q becomes zero. Thus, at the end of the   |     #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#     |first loop the number of letters in the variable is equal to the total number        |     #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#     |of states.                                                                          _|     #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#      _____________________________________________________________________________________      #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# d = |Represents the total number of states and is the length of \"a\" variable.            _|     #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#      _____________________________________________________________________________________      #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# m = |The main probability matrix which the function produces.                            _|     #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#      _____________________________________________________________________________________      #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# k = |Represents the length of the \"S\" string.                                            _|     #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#      _____________________________________________________________________________________      #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# e = |It is a matrix with two columns, namely column 0 and 1. Column 0 stores all the      |     #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#     |letters found in \"a\". Column 1 stores the number of appearances for each type        |     #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#     |of letter in \"S\".                                                                   _|     #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#      _____________________________________________________________________________________      #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'# l = |Is a vector with two components. Vector \"l\" contains the \"i\" and \"i+1\" letters       |     #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#     |from \"S\".                                                                           _|     #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'#                                                                                                 #"
      - kind: Newline
        text: "\r\n"
      - kind: EndOfLineComment
        text: "'###################################################################################################"
      - kind: Newline
        text: "\r\n"
      - kind: Newline
        text: "\r\n"

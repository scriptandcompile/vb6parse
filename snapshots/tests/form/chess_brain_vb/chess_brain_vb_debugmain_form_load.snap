                text: "'  With txtIO"
              - kind: Newline
                text: "\r\n"
              - kind: EndOfLineComment
                text: "'    .Move .Left, .Top, Me.ScaleWidth - (.Left * 2), Me.ScaleHeight - 800"
              - kind: Newline
                text: "\r\n"
              - kind: EndOfLineComment
                text: "'  End With"
              - kind: Newline
                text: "\r\n"

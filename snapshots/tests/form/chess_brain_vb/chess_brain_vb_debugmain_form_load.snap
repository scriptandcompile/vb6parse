                text: "'"
              - kind: Newline
                text: "\r\n"
              - kind: EndOfLineComment
                text: "'  cboFakeInput.Width = txtIO.Width - cmdFakeInput.Width - 100"
              - kind: Newline
                text: "\r\n"
              - kind: EndOfLineComment
                text: "'  cmdFakeInput.Left = cboFakeInput.Left + cboFakeInput.Width + 100"
              - kind: Newline
                text: "\r\n"
              - kind: EndOfLineComment
                text: "'  On Local Error GoTo 0"
              - kind: Newline

                text: "\r\n"
              - kind: Whitespace
                text: "  "
              - kind: EndOfLineComment
                text: "'###WIN32 sTitle = StrConv(\"Select location of winboard.exe (or use ARENA GUI) :\", vbFromUnicode)"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "  "
              - kind: EndOfLineComment
                text: "'###WIN32 BInfo.hwndOwner = Me.hWnd"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "  "
              - kind: EndOfLineComment
                text: "'###WIN32 BInfo.lpszTitle = StrPtr(sTitle)"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "  "
              - kind: EndOfLineComment
                text: "'###WIN32 BInfo.ulFlags = BIF_RETURNONLYFSDIRS"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "  "
              - kind: EndOfLineComment
                text: "'###WIN32 lpIdList = SHBrowseForFolder(BInfo)"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "  "
              - kind: EndOfLineComment
                text: "'###WIN32 If lpIdList Then"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "  "
              - kind: EndOfLineComment
                text: "'###WIN32     sFolderName = String$(260, 0)"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "  "
              - kind: EndOfLineComment
                text: "'###WIN32     SHGetPathFromIDList lpIdList, sFolderName"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "  "
              - kind: EndOfLineComment
                text: "'###WIN32     sFolderName = Left$(sFolderName, InStr(sFolderName, Chr(0)) - 1)"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "  "
              - kind: EndOfLineComment
                text: "'###WIN32     CoTaskMemFree lpIdList"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "  "
              - kind: EndOfLineComment
                text: "'###WIN32 End If"
              - kind: Newline
                text: "\r\n"
              - kind: Whitespace
                text: "  "
              - kind: EndOfLineComment
                text: "'###WIN32 BrowseForFolders = sFolderName"
              - kind: Newline
